# URL del backend API (producción Railway / local)
NUXT_PUBLIC_BACKEND_URL=https://vitrinepro-bakend-production.up.railway.app

# URL del frontend (para redirecciones OAuth, etc)
NUXT_PUBLIC_FRONTEND_URL=http://localhost:4321

# Entorno (development | production)
NUXT_PUBLIC_ENVIRONMENT=development

# OAuth - Google (https://console.cloud.google.com)
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# OAuth - LinkedIn (https://www.linkedin.com/developers)
NUXT_PUBLIC_LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
